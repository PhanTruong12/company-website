# Copy to .env (never commit .env). Production: set these in hosting dashboard.

NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tndgranite

JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=7d

# CORS — production: comma-separated frontend URLs
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Cloudinary — REQUIRED when NODE_ENV=production (upload middleware fails fast without valid config)
# CLOUDINARY_CLOUD_NAME must be lowercase (a-z, 0-9, _, -)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: persistent local uploads only if NOT using Cloudinary (dev / legacy)
# UPLOAD_ROOT=/data/uploads
