# Copy to .env and fill values. Vite only exposes vars prefixed with VITE_.

# Backend API (Railway hoặc URL đầy đủ; có thể chỉ origin — code tự thêm /api nếu thiếu)
# VITE_API_BASE_URL=https://your-backend.railway.app
# hoặc: https://your-backend.railway.app/api
# VITE_ENABLE_REALTIME=true
# Optional override for socket host (defaults from API base): VITE_SOCKET_URL=https://your-backend.railway.app

# Reference images (visualizer / optional)
# VITE_KITCHEN_REFERENCE_URL=https://res.cloudinary.com/...
# VITE_STAIRS_REFERENCE_URL=https://res.cloudinary.com/...
